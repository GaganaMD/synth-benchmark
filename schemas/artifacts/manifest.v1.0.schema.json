  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "dataset_version": {
      "type": "string"
    },
    "environment_version": {
      "type": "string"
    },
    "experiment_id": {
      "type": "string"
    },
    "fixture_version": {
      "type": "string"
    },
    "git_commit": {
      "type": "string"
    },
    "harness_id": {
      "type": "string"
    },
    "model_id": {
      "type": "string"
    },
    "replay": {
      "type": "object"
    },
    "run_id": {
      "type": "string"
